TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

POLYMARKET_GAMMA_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_BASE=https://clob.polymarket.com
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_OPENAI_MATCHER=false

DATABASE_URL=sqlite:///./screener.sqlite3

MIN_SPREAD_BPS=1
MIN_SIZE_USD=10
ACTIVE_MARKET_SCAN_INTERVAL_SECONDS=120
MARKET_DISCOVERY_INTERVAL_SECONDS=60
ALERT_COOLDOWN_SECONDS=300
ALERT_MIN_INTERVAL_SECONDS=0
MAX_ALERTS_PER_CYCLE=3
MAX_PRICE_STALENESS_SECONDS=5
GAMMA_PAGE_LIMIT=200
MAX_MARKETS_PER_DISCOVERY=5000
CLOB_PRICE_BATCH_SIZE=250
LOG_LEVEL=INFO
LOG_MARKET_SAMPLES=true
LOG_MARKET_SAMPLE_SIZE=5
LOG_TOP_CANDIDATES=true
LOG_TOP_CANDIDATES_LIMIT=5
LOG_TOP_CANDIDATES_EVERY_CYCLES=6
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true

KALSHI_MARKET_LIMIT=1000
KALSHI_MAX_PAGES=3
KALSHI_INCLUDE_MULTILEG=false
CROSS_VENUE_MAX_POLYMARKET_MARKETS=1000
CROSS_VENUE_MAX_KALSHI_MARKETS=500
CROSS_VENUE_MAX_CANDIDATES=50
CROSS_VENUE_MIN_MATCH_SCORE=0.07
CROSS_VENUE_MIN_EXACT_SCORE=0.72
MIN_NET_EDGE_BPS=200
CROSS_VENUE_FEE_BPS=0
EXACT_MATCH_MISMATCH_BUFFER_BPS=100
NEAR_MATCH_MISMATCH_BUFFER_BPS=500
ALLOW_NEAR_MATCH_OPPORTUNITIES=true
LOG_CROSS_VENUE_CANDIDATES=true
LOG_CROSS_VENUE_REJECTIONS=true

IMPLICATION_MAX_MARKETS=1000
IMPLICATION_MAX_CANDIDATES=20
IMPLICATION_MIN_MATCH_SCORE=0.18
IMPLICATION_MIN_ANCHOR_YES_BPS=8500
IMPLICATION_MIN_EDGE_BPS=200
IMPLICATION_BUFFER_BPS=200
IMPLICATION_FEE_BPS=0
ALLOW_HEURISTIC_IMPLICATIONS=false
LOG_IMPLICATION_CANDIDATES=true
